[node name="Area2D" type="Area2D" parent="Jaoa" unique_id=1684762014]
position = Vector2(0, -8)
script = ExtResource("6_m82gj")
npc_name = "Jaoa"
dialogue_lines = Array[String](["Hey there. You here for the alumni event too? ", "Kaid: I am. Say, do I remember you? Didn’t your name begin with a J?", "Uh, oh, uhm. Wow. I didn’t think anyone knew who I was. Yeah, it does start with a J. Joao.", "Kaid: You were in the city service club! I think I drove you once to an event. Funny, how these small interactions stick with you.", "Yeah. Yeah. It really is crazy. Thanks for saying hi. He smiles.", "Kaid: Kaid remembers another smile from her past. A smile that had been very important at the time. She had said something funny in response to a teacher's question, and everyone had laughed. But Yang, whose name she learned later, had given her such a wide grin."])
choices_lines = Array[String](["Wait, do I remember you?"])

