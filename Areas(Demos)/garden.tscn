[node name="Area2D" type="Area2D" parent="Teacher" unique_id=705479053]
position = Vector2(1, 0)
scale = Vector2(1, 1.3)
script = ExtResource("6_m82gj")
npc_name = "Selena"
dialogue_lines = Array[String](["Hi deary! What brings you around here? Not many people visit this garden.", "Kaid: I’m here for the alumni event they are holding in the gym. But it hasn’t started yet, so I thought I’d wander around.", "Ah, to be young, but not so young. To admire the flowers while not needing to tend them.", "Kaid: I’m not sure I really understand what you are talking about, but you remind me of a poetry teacher I had…", "Were you one of my students? I’ve had so many of them, you know.", "Kaid remembers sitting in a poetry class for gen education, but not the teacher’s face. She never liked her poetry much. She hadn’t been much of a writer. But even with simple words, she’d at least been able to rhyme. And Yang loved them."])
choices_lines = Array[String](["Just wandering around."])

