[node name="Area2D" type="Area2D" parent="Eve" unique_id=618494494]
position = Vector2(0, -8)
script = ExtResource("6_m82gj")
npc_name = "Eve"
dialogue_lines = Array[String](["OMG it’s Kaid!  You were in Brianna’s dorm! You always wore that cute dress to any event. ", " Kaid: I didn’t realize anyone remembered that dress. It became kind of old and frayed by the time college ended... ", "But it was great! I’m sure you got your money’s worth with it! Say, have you seen Yang? He’s still wearing that scarf he always used to! ", "Kaid: Wait, Yang actually is here? Are you sure? Didn’t he never like events?", "Are you kidding? He was always there, even if at the back. Don’t you remember at the club festival, he got stuck in a booth because it was so crowded? It was hilarious! ", "Kaid: Kaid remembers Yang, long scarf dangling, turning blue as he reached out from a tight crowd, their friends cackling with laughter."])
choices_lines = Array[String](["You remember that dress?"])

[node name="CollisionShape2D" type="CollisionShape2D" parent="Eve/Area2D" unique_id=607929427]
